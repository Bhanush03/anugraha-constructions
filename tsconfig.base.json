{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "@anugraha/api-spec": ["lib/api-spec/src/index.ts"],
      "@anugraha/api-client-react": ["lib/api-client-react/src/index.ts"],
      "@anugraha/api-zod": ["lib/api-zod/src/index.ts"]
    }
  }
}
