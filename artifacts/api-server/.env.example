# Optional locally; omit it to use the built-in persistent PGlite database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/anugraha
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=project-image
SESSION_SECRET=replace-with-a-long-random-secret
JWT_SECRET=replace-with-a-long-random-jwt-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ALLOW_PASSWORDLESS_ADMIN=false
PORT=3001
# Optional: WhatsApp notification webhook (POST { to, message })
# WHATSAPP_API_URL=https://example.com/whatsapp/send
# WHATSAPP_API_TOKEN=your_api_token_here
